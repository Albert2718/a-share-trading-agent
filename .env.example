# Copy this file to .env and fill in your keys.
TAVILY_API_KEY=""

# OpenAI-compatible LLM config.
# You can use either the generic LLM_* names or OpenAI-compatible aliases.
LLM_API_KEY=""
LLM_MODEL_ID="gpt-4o-mini"
LLM_BASE_URL=""
LLM_TIMEOUT="60"

# Also supported:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL=""
# NEWS_AGENT_MODEL="gpt-4o-mini"

AKSHARE_CACHE_TTL="86400"

# Full-stack backend. Defaults are suitable for local Docker development.
APP_ENV="development"
API_V1_PREFIX="/api/v1"
JWT_SECRET_KEY="replace_with_a_long_random_secret"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
QDRANT_COLLECTION="knowledge_chunks"
EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"
EMBEDDING_DIMENSION="512"
CHUNK_SIZE="800"
CHUNK_OVERLAP="120"
MAX_UPLOAD_SIZE_MB="20"
